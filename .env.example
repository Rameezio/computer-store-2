# Frontend Environment Variables — Copy to .env and fill values

# Backend API URL (local dev)
VITE_API_URL=http://localhost:5001/api
# Production: VITE_API_URL=https://your-api-domain.com/api

# WhatsApp number for orders (format: 92XXXXXXXXXX — no + or spaces)
VITE_WHATSAPP_NUMBER=923041109928

# App name
VITE_APP_NAME=Al-Quresh Traders
